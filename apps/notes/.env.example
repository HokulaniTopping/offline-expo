# Copy to `.env.local` (gitignored) and adjust for your setup.
# `localhost` only works from a simulator/emulator on the same machine — use your
# LAN IP for a physical device.
EXPO_PUBLIC_BACKEND_URL=http://localhost:8091

# No real login yet — which demo identity this device acts as (see
# powersync/backend/src/auth.ts for the available demo users, e.g. user-a/user-b).
EXPO_PUBLIC_DEMO_USER=user-a
