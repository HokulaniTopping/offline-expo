# Copy this file to `.env` in this same directory before running docker compose.
# `.env` is gitignored — it's local dev state, not something to commit.

# ==================== Source Postgres (the app's data) =====================
PG_DATABASE_NAME=postgres
PG_DATABASE_PORT=5432
PG_DATABASE_USER=postgres
PG_DATABASE_PASSWORD=postgres
PS_DATA_SOURCE_URI=postgres://${PG_DATABASE_USER}:${PG_DATABASE_PASSWORD}@pg-db:${PG_DATABASE_PORT}/${PG_DATABASE_NAME}

# ==================== Storage Postgres (PowerSync's internal bucket state) =
PG_STORAGE_DATABASE_NAME=postgres
PG_STORAGE_DATABASE_PORT=5431
PG_STORAGE_DATABASE_USER=postgres
PG_STORAGE_DATABASE_PASSWORD=postgres
PS_STORAGE_SOURCE_URI=postgres://${PG_STORAGE_DATABASE_USER}:${PG_STORAGE_DATABASE_PASSWORD}@pg-storage:${PG_STORAGE_DATABASE_PORT}/${PG_STORAGE_DATABASE_NAME}

# ==================== PowerSync service =====================================
PS_PORT=8080

# Filled in automatically by `node scripts/generate-keys.mjs` — do not edit by hand.
PS_JWK_KID=
PS_JWK_N=
PS_JWK_E=

# ==================== Backend API (mints tokens, applies writes to Postgres) ==
# 8081 clashes with Metro's default dev-server port — use something else.
BACKEND_PORT=8091

# Reachable-from-device URL for the PowerSync service (returned by the backend's
# /api/auth/token endpoint as the connect endpoint). `localhost` only works from
# a simulator/emulator on the same machine — override to your LAN IP for a
# physical device.
PS_PUBLIC_URL=http://localhost:8080
