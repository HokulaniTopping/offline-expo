{
  "name": "@offline-expo/sync-client",
  "version": "0.1.0",
  "description": "Reusable offline-first sync layer (PowerSync) for company apps: local-first database client, REST upload connector, and sync-status UI.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "private": true,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "@powersync/common": "^1.57.0",
    "@powersync/react": "^1.10.0",
    "@powersync/web": "^1.38.0",
    "react": ">=18",
    "react-native": ">=0.76"
  }
}
