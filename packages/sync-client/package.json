{
  "name": "@offline-expo/sync-client",
  "version": "0.1.0",
  "description": "Reusable offline-first sync layer (PowerSync) for company apps: local-first database client, REST upload connector, and sync-status UI.",
  "license": "MIT",
  "keywords": [
    "powersync",
    "offline-first",
    "local-first",
    "expo",
    "react-native",
    "sync",
    "sqlite"
  ],
  "homepage": "https://github.com/HokulaniTopping/offline-expo/tree/main/packages/sync-client#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HokulaniTopping/offline-expo.git",
    "directory": "packages/sync-client"
  },
  "bugs": {
    "url": "https://github.com/HokulaniTopping/offline-expo/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "clean": "rm -rf dist",
    "prepack": "npm run clean && npm run build"
  },
  "peerDependencies": {
    "@powersync/common": "^1.57.0",
    "@powersync/react": "^1.10.0",
    "@powersync/web": "^1.38.0",
    "react": ">=18",
    "react-native": ">=0.76"
  }
}
